# ==============================================================================
# eGED-ABMed Configuration - Environnement & Serveur On-Premise
# ==============================================================================

# Port d'écoute de l'application sur la machine hôte
APP_PORT_HOST=80
APP_URL=http://localhost

# Clé secrète de chiffrement des sessions utilisateur (générer une clé aléatoire forte en production)
NEXTAUTH_SECRET=ABMed_Session_Token_Secret_2026_Secure_Key

# ==============================================================================
# BASE DE DONNÉES POSTGRESQL (Docker / Serveur Local)
# ==============================================================================
DB_PORT_HOST=5432
DB_NAME=eged_db
DB_USER=eged_admin
# À modifier impérativement pour la production !
DB_PASSWORD=ABMed_Secure_Pass_2026

# URL de connexion directe à PostgreSQL (utilisée si migration hors Supabase active)
DATABASE_URL=postgres://eged_admin:ABMed_Secure_Pass_2026@eged-db:5432/eged_db?schema=public

# ==============================================================================
# CLIENT SUPABASE (Pour le prototypage et l'environnement de développement)
# ==============================================================================
# Laisser ces valeurs configurées si l'application s'appuie sur le client Supabase
NEXT_PUBLIC_SUPABASE_URL=https://eqqdjqdbbwmshllqesdt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder_anon_key

# ==============================================================================
# GESTION DES FICHIERS & GED (Stockage local On-Premise)
# ==============================================================================
# Driver de stockage : local (dossier local/NAS) ou s3 (compatible S3)
STORAGE_DRIVER=local

# Répertoire local de stockage des fichiers sur le serveur hôte
# Sous Docker, ce dossier est mappé dans le volume persistant "uploads"
STORAGE_LOCAL_PATH=/app/uploads

# Paramètres de stockage S3 (Optionnel, si l'ABMed active le stockage S3/MinIO à l'avenir)
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=

# ==============================================================================
# BACKUPS / SAUVEGARDES
# ==============================================================================
# Répertoire où seront stockés les dumps SQL et archives compressées
BACKUP_DIR=./backups
# Durée de rétention des sauvegardes en jours
BACKUP_RETENTION_DAYS=30
